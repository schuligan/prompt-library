# Copy to .env and fill in if you want to run the eval harness against a real model.
# The harness DEFAULTS TO A DETERMINISTIC MOCK and runs fully offline with no key set.

# Optional: enables the real-model path in evals/run.py when present.
ANTHROPIC_API_KEY=

# Optional: override the default model id used on the live path.
# ANTHROPIC_MODEL=claude-sonnet-4-5
