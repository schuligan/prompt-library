{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SentimentClassification",
  "type": "object",
  "additionalProperties": false,
  "required": ["label", "confidence", "rationale"],
  "properties": {
    "label": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "mixed"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "maxLength": 200
    }
  }
}
